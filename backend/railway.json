{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "./pocketbase serve --http=0.0.0.0:8080",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300
  }
}